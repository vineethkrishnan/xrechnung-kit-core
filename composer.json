{
    "name": "vineethkrishnan/xrechnung-kit-core",
    "description": "EN 16931 / XRechnung 3.0 compliant e-invoice generator and validator. Framework-agnostic core.",
    "type": "library",
    "license": "MIT",
    "keywords": ["xrechnung", "en16931", "e-invoicing", "peppol", "ubl", "germany", "invoicing"],
    "homepage": "https://github.com/vineethkrishnan/xrechnung-kit",
    "support": {
        "issues": "https://github.com/vineethkrishnan/xrechnung-kit/issues",
        "source": "https://github.com/vineethkrishnan/xrechnung-kit",
        "docs": "https://github.com/vineethkrishnan/xrechnung-kit/tree/main/docs",
        "security": "https://github.com/vineethkrishnan/xrechnung-kit/blob/main/SECURITY.md"
    },
    "authors": [
        { "name": "Vineeth N K", "email": "me@vineethnk.in", "role": "Maintainer" }
    ],
    "require": {
        "php": "^8.1",
        "ext-dom": "*",
        "ext-libxml": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0 || ^12.0"
    },
    "suggest": {
        "psr/log": "Wire your application's PSR-3 logger into the validator alert pipeline.",
        "vineethkrishnan/xrechnung-kit-kosit-bundle": "Adds KoSIT Schematron validation alongside the bundled UBL XSD validation.",
        "vineethkrishnan/xrechnung-kit-laravel": "Laravel service provider, facade, and queueable job.",
        "vineethkrishnan/xrechnung-kit-symfony": "Symfony bundle and DI extension.",
        "vineethkrishnan/xrechnung-kit-cakephp": "CakePHP plugin and service.",
        "vineethkrishnan/xrechnung-kit-laminas": "Laminas module and service factory."
    },
    "autoload": {
        "psr-4": {
            "XrechnungKit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "XrechnungKit\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.x-dev"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
